# Neon Postgres (server-side only — Netlify Environment Variables)
DATABASE_URL=postgresql://user:password@ep-xxx.eu-central-1.aws.neon.tech/neondb?sslmode=require

# Secret for JWT tokens (any long random string)
JWT_SECRET=change-me-to-a-long-random-secret

# --- Optional: Google Drive secondary (mirror) storage ---
# Media keeps being served from Netlify Blobs; Drive is just a parallel copy.
# Enable only when all three credentials are set.
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_REFRESH_TOKEN=your-refresh-token
# Optional target folder in the organizer's Drive (defaults to Drive root).
GOOGLE_DRIVE_FOLDER_ID=
